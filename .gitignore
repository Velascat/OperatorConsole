*.pyc
*.pyo
.venv/
.fob/
!.fob/*.example*

# Profiles are private by default; only platform-group members are tracked.
config/profiles/*.yaml
!config/profiles/platform.yaml
!config/profiles/controlplane.yaml
!config/profiles/fob.yaml
!config/profiles/switchboard.yaml
!config/profiles/workstation.yaml

# Saved tab layouts and Claude session IDs (captured from live sessions — always private)
config/profiles/*.kdl
config/profiles/*.session
