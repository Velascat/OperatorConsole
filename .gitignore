__pycache__/
*.pyc
*.pyo
.venv/
.console/*
!.console/task.md
!.console/backlog.md
!.console/guidelines.md
!.console/log.md

# Profiles are private by default; only platform-group members are tracked.
config/profiles/*.yaml
!config/profiles/platform.yaml
!config/profiles/operations_center.yaml
!config/profiles/operator_console.yaml
!config/profiles/switchboard.yaml
!config/profiles/workstation.yaml
!config/profiles/cxrp.yaml
!config/profiles/executorruntime.yaml
!config/profiles/sourceregistry.yaml
!config/profiles/rxp.yaml
!config/profiles/platformmanifest.yaml
!config/profiles/repograph.yaml
!config/profiles/protocolwarden.github.io.yaml

# Saved tab layouts, session IDs, and generated rc files (always private)
config/profiles/*.kdl
config/profiles/*.session
config/profiles/*.codex-session
config/profiles/status-rc-*.sh

# Warehouse data (generated artifacts gitignored via .warehouse/yard/*/.gitignore)
.warehouse/yard/
