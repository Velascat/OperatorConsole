// brief.kdl — reference layout (do not use directly)
// The launcher generates a runtime version of this at launch time.
// See: src/operator_console/launcher.py  generate_session_layout()
//
// Session layout: default_tab_template injects chrome (tab-bar + status-bar)
// into every tab. Tab content is the four-pane split below.
//
// Pane arrangement per tab:
//   Left (60%)       : Claude pane — claude --continue
//   Top-right (34%)  : git pane   — lazygit
//   Mid-right (33%)  : logs pane  — tail -f .console/runtime.log
//   Bottom-right     : shell pane — bash

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }
    tab name="<profile-name>" {
        pane split_direction="vertical" {
            pane name="claude" size="60%" command="bash" {
                args "-c" "cd '<repo_root>' && claude --continue"
            }
            pane size="40%" split_direction="horizontal" {
                pane name="git" size="34%" command="bash" {
                    args "-c" "cd '<repo_root>' && lazygit; exec bash -l"
                }
                pane name="logs" size="33%" command="bash" {
                    args "-c" "cd '<repo_root>' && tail -f .console/runtime.log 2>/dev/null; exec bash -l"
                }
                pane name="shell" command="bash" {
                    args "-c" "cd '<repo_root>' && bash '<welcome.sh>'"
                }
            }
        }
    }
}
